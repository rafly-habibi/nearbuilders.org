{
  "compilerOptions": {
    "baseUrl": ".",
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "declaration": true,
    "declarationMap": false,
    "emitDeclarationOnly": true,
    "outDir": "types",
    "paths": {
      "every-plugin": ["../packages/every-plugin/src/index.ts"],
      "every-plugin/*": ["../packages/every-plugin/src/*"],
      "every-plugin/zod/v4/core": ["../packages/every-plugin/src/zod-core.ts"]
    }
  },
  "include": ["src/contract.ts"]
}
