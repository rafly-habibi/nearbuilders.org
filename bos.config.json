      "secrets": [
        "PROJECTS_DATABASE_URL"
      ],
      "routes": [
        "ui/src/routes/_layout/_authenticated/projects/**"
      ],
      "sidebar": [
        {
          "icon": "FolderKanban",
          "label": "projects"
        }
      ],
      "production": "https://elliot-braem-4004-everything-dev-projects-plugin--eb4242c83-ze.zephyrcloud.app",
      "integrity": "sha384-Ebw6xOrPBFCd78H0ZuGt85tniTj3J+jKmSts9ULm+tQTy2yco6E5jWfflXwVUON6"
    }
