{
  "extends": "bos://dev.everything.near/dev.everything.dev",
  "account": "work.efiz.near",
  "domain": "nearbuilders.org",
  "title": "NEAR Builders",
  "description": "The open platform for builders on NEAR.",
  "testnet": "dev.allthethings.testnet",
  "staging": {
    "domain": "staging.dev.everything.dev"
  },
  "repository": "https://github.com/nearbuilders/everything-dev",
  "app": {
    "ui": {
      "development": "local:ui"
    },
    "api": {
      "development": "local:api",
      "secrets": [
        "API_DATABASE_URL"
      ]
    }
  },
  "plugins": {
    "apps": {
      "development": "local:plugins/apps",
      "variables": {
        "registryNamespace": "dev.everything.near"
      },
      "routes": [
        "ui/src/routes/_layout/apps/**"
      ],
      "sidebar": [
        {
          "icon": "Globe",
          "label": "apps",
          "roleRequired": "anon"
        }
      ]
    },
    "projects": {
      "development": "local:plugins/projects",
      "secrets": [
        "PROJECTS_DATABASE_URL"
      ],
      "routes": [
        "ui/src/routes/_layout/_authenticated/projects/**"
      ],
      "sidebar": [
        {
          "icon": "FolderKanban",
          "label": "projects"
        }
      ]
    },
    "builders": {
      "development": "local:plugins/builders",
      "secrets": [
        "BUILDERS_DATABASE_URL"
      ],
      "routes": [
        "ui/src/routes/_layout/builders/**"
      ]
    },
    "events": {
      "development": "local:plugins/events",
      "secrets": [
        "EVENTS_DATABASE_URL"
      ],
      "routes": [
        "ui/src/routes/_layout/events/**"
      ]
    },
    "proposals": {
      "development": "local:plugins/proposals",
      "secrets": [
        "PROPOSALS_DATABASE_URL"
      ]
    },
    "votes": {
      "development": "local:plugins/votes",
      "secrets": [
        "VOTES_DATABASE_URL"
      ]
    }
  }
}
