        "singleton": true,
        "strictVersion": false,
        "shareScope": "default"
      },
      "better-auth": {
        "version": "1.6.9",
        "requiredVersion": "^1.6.9",
        "singleton": true,
        "strictVersion": false,
        "shareScope": "default"
      },
      "better-near-auth": {
        "version": "1.5.0",
