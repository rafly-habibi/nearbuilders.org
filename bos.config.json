{
  "extends": "bos://dev.everything.near/everything.dev",
  "account": "work.efiz.near",
  "domain": "nearbuilders.org",
  "title": "NEAR Builders",
  "description": "The open platform for builders on NEAR.",
  "testnet": "dev.allthethings.testnet",
  "staging": {
    "domain": "staging.dev.everything.dev"
  },
  "repository": "https://github.com/nearbuilders/everything-dev",
  "app": {
    "ui": {
      "development": "local:ui",
      "production": "https://elliot-braem-4000-ui-monorepo-elliot-braem-9536dc1b9-ze.zephyrcloud.app",
      "integrity": "sha384-wAOHyqAYG7/HIyDuYvqX6qkouA1bEuseIkUSbjwNTUXgQLWdj3g+0ved8Axjz99j",
      "ssr": "https://elliot-braem-4001-ui-monorepo-elliot-braem-f3f7d54c6-ze.zephyrcloud.app"
    },
    "api": {
      "development": "local:api",
      "secrets": [
        "API_DATABASE_URL"
      ],
      "production": "https://elliot-braem-4002-api-monorepo-elliot-braem-95a0fd655-ze.zephyrcloud.app",
      "integrity": "sha384-b/yKcaQ3SK3uqaae1mdjXqutKCd3OlZRdrTrLNqej/IRe1nSQisO2/TP3MhHjQVk"
    }
  },
