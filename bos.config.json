      "routes": [
        "ui/src/routes/_layout/apps/**"
      ],
      "sidebar": [
        {
          "icon": "Globe",
          "label": "apps",
          "roleRequired": "anon"
        }
      ],
      "production": "https://elliot-braem-4003-everything-dev-apps-plugin-ever-0aee196ce-ze.zephyrcloud.app",
      "integrity": "sha384-y3sci4dkrrwpJFklofUct9UQlLKJeSJpiKjLwXsiIF4xH+QBRXOUYodpNOJsdrqK"
    },
    "projects": {
